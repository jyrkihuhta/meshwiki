# MeshWiki runtime environment variables
# Copy this to /opt/meshwiki/.env on the VPS and fill in values.
# Never commit the real .env file.

# ── App ──────────────────────────────────────────────────────
MESHWIKI_DATA_DIR=/data/pages

# ── Auth (M0.3) ───────────────────────────────────────────────
MESHWIKI_AUTH_ENABLED=true
# Plaintext password for single-user login
MESHWIKI_AUTH_PASSWORD=changeme
# Random hex string: python3 -c "import secrets; print(secrets.token_hex(32))"
MESHWIKI_SESSION_SECRET=

# ── Agent Factory (Phase 1+) ──────────────────────────────────
MESHWIKI_FACTORY_ENABLED=false
# Static Bearer token for orchestrator → wiki API calls.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Also add as MESHWIKI_FACTORY_API_KEY in GitHub Secrets for CI use.
MESHWIKI_FACTORY_API_KEY=
MESHWIKI_FACTORY_WEBHOOK_URL=
MESHWIKI_FACTORY_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=
POSTGRES_DSN=postgresql://meshwiki:changeme@db:5432/meshwiki
